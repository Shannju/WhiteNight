--- !u!114 &2605919493236487829
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 8722611387859447736}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: '


    <indent=5%>Last year, an elderly Italian tourist went to Norway
    to witness the longest day of the year. He sat outside his cabin with a camera,
    for he wanted to photograph the sun at exactly twelve o''clock. As the hours
    passed, the sky turned a beautiful gold, but it never grew dark.</indent>



    <indent=5%>The
    birds continued to sing and people stayed outdoors as if it were mid-day. The
    man waited patiently until the hands of his watch reached midnight. He captured
    a perfect image of the sun hanging above the sea.</indent>



    <indent=5%>''I
    have done it!'' he shouted triumphantly. However, when he finally went to bed,
    he found it impossible to fall asleep. He had been so busy watching the sun that
    he had forgotten to close the heavy curtains of his cabin.</indent>


'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 5302535af1044152a457ed104f1f4b91, type: 2}
