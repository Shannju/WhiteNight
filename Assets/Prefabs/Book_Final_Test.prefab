  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "A Because he had forgotten to close the heavy curtains of his cabin.\r\n\nB
    Because he thought the sun was a giant lamp and he couldn't find the switch to
    turn it off.\r\n\nC Because the midnight sun reminded him of a lost summer from
    his youth that would never\r return.\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 5302535af1044152a457ed104f1f4b91, type: 2}
