    m_PersistentCalls:
      m_Calls: []
  m_text: '

    <b>Xiao Yuan:</b> Look at the pink sky! It reminds me of the "White
    Night".

    <b>Chen Wen:</b> A summer where the sun never sets? What would you
    do at night?

    <b>Xiao Yuan:</b> I would read under the trees. I wouldn''t
    need a lamp at all!

    <b>Chen Wen:</b> I would swing until morning! Without
    darkness, there is no rhythm or discipline.

    <b>Xiao Yuan:</b> (Smiling)
    True, but we still have to wake up for school!

    </line-height>'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 5302535af1044152a457ed104f1f4b91, type: 2}
