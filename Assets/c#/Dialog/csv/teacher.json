                    "lines": [
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 0,
                            "text": "(Minna, the receptionist, follows him and places a stack of orange books on the lectern.)",
                            "pictureId": "",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 1,
                            "text": "(In this small town, she was everything I imagined a professional city woman to be: a business suit, black-rimmed glasses, a silver bracelet, and a faint professional smile.)",
                            "pictureId": "",
                            "playerPicture": ""
                        }
                    ]
                },
                {
                    "dialogId": "1_ap_3",
                    "day": 1,
                    "sequenceOrder": 0,
                    "actionPointMin": 3,
                    "actionPointMax": 3,
                    "lines": [
                        {
                            "speakerId": "teacher",
                            "characterName": "Julian",
                            "triggerOrder": 0,
                            "text": "hello everyone, welcome to……",
                            "pictureId": "",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "teacher",
                            "characterName": "Julian",
                            "triggerOrder": 1,
                            "text": "Beyond English Summer Course.",
                            "pictureId": "",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "teacher",
                            "characterName": "Julian",
                            "triggerOrder": 2,
                            "text": "Look at me!",
                            "pictureId": "",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 3,
                            "text": "!",
                            "pictureId": "",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 4,
                            "text": "(Minna timely closes the door and leaves. Sound: door creaks shut~~)",
                            "pictureId": "",
                            "playerPicture": ""
                        }
                    ]
                },
                {
                    "dialogId": "1_ap_4",
                    "day": 1,
                    "sequenceOrder": 0,
                    "actionPointMin": 4,
                    "actionPointMax": 4,
                    "lines": [
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 0,
                            "text": "(He turns and scrawls a huge **JULIAN** on the whiteboard with a marker. Sound: marker squeaking.)",
                            "pictureId": "",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 1,
                            "text": "(I'm Julian. Your teacher for this summer course.)",
                            "pictureId": "",
                            "playerPicture": ""
                        }
                    ]
                },
                {
                    "dialogId": "1_ap_5",
                    "day": 1,
                    "sequenceOrder": 0,
                    "actionPointMin": 5,
                    "actionPointMax": 5,
                    "lines": [
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 0,
                            "text": "(Look at this word—**July**. The best month of the year.)",
                            "pictureId": "",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 1,
                            "text": "(Add an **'an'** at the end. In Latin, this means 'belonging to July'.)",
                            "pictureId": "",
                            "playerPicture": ""
                        }
                    ]
                },
                {
                    "dialogId": "1_ap_6",
                    "day": 1,
                    "sequenceOrder": 0,
                    "actionPointMin": 6,
                    "actionPointMax": 6,
                    "lines": [
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 0,
                            "text": "(When I was studying abroad, on a beach over there, I told myself: Julian, you must be like the scorching sun of July, burning away all mediocrity and cowardice!)",
                            "pictureId": "",
                            "playerPicture": ""
                        }
                    ]
                },
                {
                    "dialogId": "1_ap_7",
                    "day": 1,
                    "sequenceOrder": 0,
                    "actionPointMin": 7,
                    "actionPointMax": 7,
                    "lines": [
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 0,
                            "text": "(English is the easiest language in the world! As long as you dare to shout it out, you can overcome it, and overcome yourself.)",
                            "pictureId": "",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 1,
                            "text": "(Come on, follow me!)",
                            "pictureId": "",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 2,
                            "text": "(Beyond English)",
                            "pictureId": "",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 3,
                            "text": "Beyond English",
                            "pictureId": "",
