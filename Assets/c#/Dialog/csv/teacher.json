                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 2,
                            "text": "(Add an **'an'** at the end. In Latin, this means 'belonging to July'.)",
                            "pictureId": "",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 3,
                            "text": "(When I was studying abroad, on a beach over there, I told myself: Julian, you must be like the scorching sun of July, burning away all mediocrity and cowardice!)",
