                            "playerPicture": ""
                        },
                        {
                            "speakerId": "tutorial",
                            "characterName": "",
                            "triggerOrder": 5,
                            "text": "Actually, you can also use the up, down, left, and right arrow keys to view freely……",
                            "pictureId": "",
