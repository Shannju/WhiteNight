{
    "characters": [
        {
            "characterId": "mate",
            "characterName": "Cici",
            "mode": "sequence",
            "dialogs": [
                {
                    "dialogId": "1_seq_0",
                    "day": 1,
                    "sequenceOrder": 0,
                    "actionPointMin": 0,
                    "actionPointMax": 0,
                    "lines": [
                        {
                            "speakerId": "mate",
                            "characterName": "Cici",
                            "triggerOrder": 0,
                            "text": "Who cares about grades? Summer vacation has already started!",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 1,
                            "text": "I wish I could, but holiday is basically we catching up on English.",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "mate",
                            "characterName": "Cici",
                            "triggerOrder": 2,
                            "text": "Worst luck ever. We sre the ones who have to deal with Julian this term.",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "mate",
                            "characterName": "Cici",
                            "triggerOrder": 3,
                            "text": "His teaching style is... insane.",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "tutorial",
                            "characterName": "",
                            "triggerOrder": 4,
                            "text": "Press the up key to look at the blackboard.",
                            "pictureId": "3",
                            "playerPicture": ""
                        }
                    ]
                },
                {
                    "dialogId": "1_seq_2",
                    "day": 1,
                    "sequenceOrder": 2,
                    "actionPointMin": 0,
                    "actionPointMax": 0,
                    "lines": [
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 0,
                            "text": "(Cici is my only and best friend.)",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 1,
                            "text": "(She's the type to be affected by grades too, but she doesn't dwell on it.)",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 2,
                            "text": "(I can talk to other classmates, of course. We say hi when we see each other.)",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 3,
                            "text": "(But if I can see my dearest Cici at school every day...)",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 4,
                            "text": "(partner with her in P.E. class and line up with her without a second thought...)",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 5,
                            "text": "(and go home with her after school...)",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 6,
                            "text": "(and just do homework the rest of the time...)",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 7,
                            "text": "(Life is so blissful that I have no time to think about anything else.)",
                            "pictureId": "3",
                            "playerPicture": ""
                        }
                    ]
                },
                {
                    "dialogId": "1_seq_3",
                    "day": 1,
                    "sequenceOrder": 3,
                    "actionPointMin": 0,
                    "actionPointMax": 0,
                    "lines": [
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 0,
                            "text": "Of course! Let me play Aoi Prism!",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 1,
                            "text": "Last time I opened a music game at home, my mom told me I might as well be playing the piano.",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "mate",
                            "characterName": "Cici",
                            "triggerOrder": 2,
                            "text": "Haha, that's totally different.",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "mate",
                            "characterName": "Cici",
                            "triggerOrder": 3,
                            "text": "Maybe she just doesn't like seeing you play games.",
                            "pictureId": "3",
                            "playerPicture": ""
                        }
                    ]
                },
                {
                    "dialogId": "1_seq_4",
                    "day": 1,
                    "sequenceOrder": 4,
                    "actionPointMin": 0,
                    "actionPointMax": 0,
                    "lines": [
                        {
                            "speakerId": "mate",
                            "characterName": "Cici",
                            "triggerOrder": 0,
                            "text": "My mom says I should study abroad in the future.",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "mate",
                            "characterName": "Cici",
                            "triggerOrder": 1,
                            "text": "Julian is the founder of this school.",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "mate",
                            "characterName": "Cici",
                            "triggerOrder": 2,
                            "text": "It wasn't easy to get you into his class.",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 3,
                            "text": "I know. Thank you!",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "mate",
                            "characterName": "Cici",
                            "triggerOrder": 4,
                            "text": "His teaching style is... insane.",
                            "pictureId": "3",
                            "playerPicture": ""
                        }
                    ]
                },
                {
                    "dialogId": "1_seq_5",
                    "day": 1,
                    "sequenceOrder": 5,
                    "actionPointMin": 0,
                    "actionPointMax": 0,
                    "lines": [
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 0,
                            "text": "(When Cici chants along, only her mouth moves.)",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 1,
                            "text": "(It's more like a silent film performance.)",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 2,
                            "text": "(Her mouth shapes are exaggerated, but her voice lacks the enthusiasm Julian expects.)",
                            "pictureId": "3",
                            "playerPicture": ""
                        }
                    ]
                },
                {
                    "dialogId": "1_seq_6",
                    "day": 1,
                    "sequenceOrder": 6,
                    "actionPointMin": 0,
                    "actionPointMax": 0,
                    "lines": [
                        {
                            "speakerId": "mate",
                            "characterName": "Cici",
                            "triggerOrder": 0,
                            "text": "I want to drop this class!",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 1,
                            "text": "Would your mom agree to that?",
                            "pictureId": "3",
                            "playerPicture": ""
                        },
                        {
                            "speakerId": "player",
                            "characterName": "Me",
                            "triggerOrder": 2,
                            "text": "(Cici looks out the window, dejected.)",
                            "pictureId": "3",
                            "playerPicture": ""
                        }
                    ]
                }
            ]
        }
    ]
}
